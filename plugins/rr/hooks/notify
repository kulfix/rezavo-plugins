#!/usr/bin/env python3
"""Notification hook — sends push via ntfy with Claude's prepared summary."""
import json
import os
import subprocess
import sys
import time

MIN_ELAPSED = 60
NTFY_URL = "https://ntfy.wczasowa8.pl/claude-code"
TIMESTAMP_FILE = "/tmp/.claude-last-prompt-ts"
SUMMARY_FILE = "/tmp/.claude-stop-summary"


def check_throttle() -> bool:
    try:
        with open(TIMESTAMP_FILE) as f:
            last_prompt = int(f.read().strip())
        return (int(time.time()) - last_prompt) >= MIN_ELAPSED
    except (FileNotFoundError, ValueError):
        return True


def get_summary() -> str | None:
    try:
        with open(SUMMARY_FILE) as f:
            text = f.read().strip()
        os.remove(SUMMARY_FILE)
        return text if text else None
    except FileNotFoundError:
        return None


def get_git_context() -> tuple[str, str]:
    project, branch = "", ""
    try:
        r = subprocess.run(["git", "rev-parse", "--show-toplevel"],
                           capture_output=True, text=True, timeout=5)
        project = os.path.basename(r.stdout.strip()) if r.stdout.strip() else ""
    except Exception:
        pass
    try:
        r = subprocess.run(["git", "branch", "--show-current"],
                           capture_output=True, text=True, timeout=5)
        branch = r.stdout.strip()
    except Exception:
        pass
    return project, branch


def send_ntfy(title: str, body: str, tag: str):
    try:
        subprocess.run(
            ["curl", "-s", "-o", "/dev/null",
             "-H", f"Title: {title}",
             "-H", "Priority: default",
             "-H", f"Tags: {tag}",
             "-d", body,
             NTFY_URL],
            timeout=10, capture_output=True
        )
    except Exception:
        pass


def main():
    json.load(sys.stdin)  # consume stdin

    if not check_throttle():
        sys.exit(0)

    summary = get_summary()
    if not summary:
        sys.exit(0)

    tag = "question" if "?" in summary else "white_check_mark"

    project, branch = get_git_context()
    title = "Claude Code"
    if project:
        title += f" | {project}"
    if branch:
        title += f" [{branch}]"

    send_ntfy(title, summary, tag)


if __name__ == "__main__":
    main()
