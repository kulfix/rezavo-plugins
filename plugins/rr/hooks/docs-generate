#!/usr/bin/env bash
# PostToolUse hook — auto-regenerate reference docs after git commit
# If project has scripts/generate_docs.py, run it after commits touching app/ files.
set -euo pipefail

input=$(cat)

tool_name=$(echo "$input" | jq -r '.tool_name // ""')
[ "$tool_name" = "Bash" ] || exit 0

command=$(echo "$input" | jq -r '.tool_input.command // ""')

# Only trigger on git commit commands
echo "$command" | grep -qE '(^|&&\s*|\|\|\s*|;\s*)git commit' || exit 0

# Check if project has generate_docs.py
[ -f "scripts/generate_docs.py" ] || exit 0

# Run generation
python scripts/generate_docs.py > /dev/null 2>&1 || exit 0

# Check if generated docs changed
if ! git diff --quiet docs/kb/generated/ 2>/dev/null; then
    git add docs/kb/generated/ 2>/dev/null || true
    cat <<'EOF'
{
  "systemMessage": "Reference docs in docs/kb/generated/ are stale after this commit. They have been staged — create a new commit to include them, e.g.: git commit -m 'docs: regenerate reference docs'"
}
EOF
    exit 0
fi

exit 0
